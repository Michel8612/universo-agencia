{
  "name": "UNIVERSO HUB — Orquestador Central",
  "nodes": [
    {
      "id": "hub1",
      "name": "Webhook Agencia",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "parameters": {
        "path": "agencia",
        "responseMode": "onReceived",
        "httpMethod": "POST"
      }
    },
    {
      "id": "hub2",
      "name": "Llamar API Agencia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [560, 300],
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8080/dispatch",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.body }}",
        "timeout": 120000,
        "options": {}
      }
    }
  ],
  "connections": {
    "Webhook Agencia": {
      "main": [[{"node": "Llamar API Agencia", "type": "main", "index": 0}]]
    }
  },
  "settings": {"executionOrder": "v1"}
}
