# ============================================
# UNIVERSO AGENCIA IA — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a GitHub
# ============================================

# === IA / CEREBRO ===
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# Modelos disponibles: anthropic/claude-sonnet-4-6, anthropic/claude-opus-4-8

# === GROQ (IA rapida y gratis en la nube — usado por las herramientas de mundo-ventas) ===
# Crea la key gratis en https://console.groq.com/keys
# Si defines GROQ_API_KEY, las herramientas (buscar-trabajos, diagnostico, scraper,
# campana, propuestas) usan Groq. Si no, caen automaticamente a Ollama local.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# === OLLAMA (fallback local, gratis) ===
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:14b

# === SLACK (avisos internos de leads) ===
# Crea un Incoming Webhook en https://api.slack.com/messaging/webhooks
# y pega aqui la URL. Si esta vacio, no se envian avisos (no rompe nada).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === TELEGRAM ===
# @username de tu bot (sin la @). Se usa para el boton "Habla con el asistente"
# de la web. Ponlo tambien en la constante TELEGRAM_BOT de web-nexia/src/app/page.tsx
TELEGRAM_BOT_USERNAME=TuBot

# === n8n ===
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=tu-api-key-de-n8n
N8N_SOCIAL_WEBHOOK=http://localhost:5678/webhook/publish-social

# === INSTAGRAM / META ===
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxx
INSTAGRAM_ACCOUNT_ID=17841xxxxxxxxxx
FACEBOOK_PAGE_ID=xxxxxxxxxxxxxx

# === TWITTER / X ===
TWITTER_API_KEY=xxxxxxxxxxxxxx
TWITTER_API_SECRET=xxxxxxxxxxxxxx
TWITTER_ACCESS_TOKEN=xxxxxxxxxxxxxx
TWITTER_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxx

# === TIKTOK ===
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxx
TIKTOK_OPEN_ID=xxxxxxxxxxxxxx

# === LINKEDIN ===
LINKEDIN_ACCESS_TOKEN=xxxxxxxxxxxxxx
LINKEDIN_ORG_ID=xxxxxxxxxxxxxx

# === YOUTUBE ===
YOUTUBE_API_KEY=xxxxxxxxxxxxxx
YOUTUBE_CLIENT_ID=xxxxxxxxxxxxxx
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=xxxxxxxxxxxxxx

# === GOOGLE DRIVE (para almacenar contenido) ===
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=xxxxxxxxxxxxxx
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxx

# === CUENTAS ACTIVAS (JSON array para n8n) ===
# Cada objeto: { nombre, nicho, plataformas[] }
CUENTAS_ACTIVAS=[{"nombre":"mi-marca","nicho":"negocios digitales e IA","plataformas":["instagram","twitter","linkedin"]}]
